# Azure AI Foundry — set these to your project's values
# Get the endpoint from: Azure AI Foundry portal → your project → Overview
AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/

# Model deployment names — must match what's deployed in your Foundry project
# Works with GPT-5, GPT-4.1, GPT-4o, or any chat completion model
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5
AZURE_OPENAI_MINI_DEPLOYMENT_NAME=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-large
